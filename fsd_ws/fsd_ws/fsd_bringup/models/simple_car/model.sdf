<?xml version="1.0"?>
<!-- 差速小车 + 传感器（坐标系：base_link 为前-左-上 FLU） -->
<sdf version="1.9">
  <model name="simple_car">

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_rear_wheel_joint</left_joint>
      <right_joint>right_rear_wheel_joint</right_joint>
      <wheel_separation>0.84</wheel_separation>
      <wheel_radius>0.16</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/sensors/wheel_odom</odom_topic>
      <frame_id>world</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <publish_odom_tf>false</publish_odom_tf>
    </plugin>

    <link name="base_link">
      <pose>0 0 0.22 0 0 0</pose>
      <inertial>
        <mass>20</mass>
        <inertia>
          <ixx>1.0</ixx><iyy>1.0</iyy><izz>1.0</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <!-- F1 风格外观（碰撞盒不变） -->
      <visual name="monocoque">
        <pose>0.02 0 0.09 0 0 0</pose>
        <geometry><box><size>0.88 0.42 0.11</size></box></geometry>
        <material><diffuse>0.82 0.04 0.08 1</diffuse></material>
      </visual>
      <visual name="nose">
        <pose>0.52 0 0.07 0 0 0</pose>
        <geometry><box><size>0.22 0.14 0.07</size></box></geometry>
        <material><diffuse>0.82 0.04 0.08 1</diffuse></material>
      </visual>
      <visual name="sidepod_l">
        <pose>-0.05 0.24 0.06 0 0 0</pose>
        <geometry><box><size>0.55 0.16 0.08</size></box></geometry>
        <material><diffuse>0.82 0.04 0.08 1</diffuse></material>
      </visual>
      <visual name="sidepod_r">
        <pose>-0.05 -0.24 0.06 0 0 0</pose>
        <geometry><box><size>0.55 0.16 0.08</size></box></geometry>
        <material><diffuse>0.82 0.04 0.08 1</diffuse></material>
      </visual>
      <visual name="engine_cover">
        <pose>-0.28 0 0.10 0 0 0</pose>
        <geometry><box><size>0.35 0.28 0.06</size></box></geometry>
        <material><diffuse>0.82 0.04 0.08 1</diffuse></material>
      </visual>
      <visual name="front_wing_main">
        <pose>0.58 0 0.025 0 0 0</pose>
        <geometry><box><size>0.06 0.72 0.015</size></box></geometry>
        <material><diffuse>0.06 0.06 0.07 1</diffuse></material>
      </visual>
      <visual name="front_wing_ep_l">
        <pose>0.56 0.34 0.05 0 0 0</pose>
        <geometry><box><size>0.04 0.02 0.08</size></box></geometry>
        <material><diffuse>0.06 0.06 0.07 1</diffuse></material>
      </visual>
      <visual name="front_wing_ep_r">
        <pose>0.56 -0.34 0.05 0 0 0</pose>
        <geometry><box><size>0.04 0.02 0.08</size></box></geometry>
        <material><diffuse>0.06 0.06 0.07 1</diffuse></material>
      </visual>
      <visual name="rear_wing_main">
        <pose>-0.54 0 0.28 0 0 0</pose>
        <geometry><box><size>0.05 0.68 0.02</size></box></geometry>
        <material><diffuse>0.06 0.06 0.07 1</diffuse></material>
      </visual>
      <visual name="rear_wing_ep_l">
        <pose>-0.52 0.32 0.22 0 0 0</pose>
        <geometry><box><size>0.03 0.02 0.18</size></box></geometry>
        <material><diffuse>0.06 0.06 0.07 1</diffuse></material>
      </visual>
      <visual name="rear_wing_ep_r">
        <pose>-0.52 -0.32 0.22 0 0 0</pose>
        <geometry><box><size>0.03 0.02 0.18</size></box></geometry>
        <material><diffuse>0.06 0.06 0.07 1</diffuse></material>
      </visual>
      <visual name="halo">
        <pose>0.08 0 0.22 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.28</radius><length>0.012</length></cylinder></geometry>
        <material><diffuse>0.06 0.06 0.07 1</diffuse></material>
      </visual>
      <visual name="cockpit">
        <pose>0.05 0 0.16 0 0 0</pose>
        <geometry><box><size>0.18 0.22 0.06</size></box></geometry>
        <material><diffuse>0.15 0.55 0.85 0.85</diffuse></material>
      </visual>
      <collision name="body_col">
        <geometry><box><size>1.2 0.7 0.22</size></box></geometry>
      </collision>

      <!-- IMU：输出车体局部坐标系角速度与线加速度 -->
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <topic>/sensors/imu/data_raw</topic>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><stddev>0.01</stddev></noise></x>
            <y><noise type="gaussian"><stddev>0.01</stddev></noise></y>
            <z><noise type="gaussian"><stddev>0.01</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><stddev>0.05</stddev></noise></x>
            <y><noise type="gaussian"><stddev>0.05</stddev></noise></y>
            <z><noise type="gaussian"><stddev>0.05</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>

      <!-- 磁力计：地磁向量，用于解算全局航向 -->
      <sensor name="mag_sensor" type="magnetometer">
        <always_on>true</always_on>
        <update_rate>50</update_rate>
        <topic>/sensors/magnetic_field</topic>
      </sensor>

      <!-- GPS -->
      <sensor name="navsat_sensor" type="navsat">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <topic>/sensors/gps/fix</topic>
      </sensor>
    </link>

    <!-- 相机：前向安装，供 RViz / 调试可视化 -->
    <link name="camera_link">
      <pose>0.55 0 0.35 0 0 0</pose>
      <inertial><mass>0.05</mass><inertia><ixx>1e-4</ixx><iyy>1e-4</iyy><izz>1e-4</izz></inertia></inertial>
      <visual name="camera_visual">
        <geometry><box><size>0.04 0.06 0.03</size></box></geometry>
        <material><diffuse>0.06 0.06 0.07 1</diffuse></material>
      </visual>
      <sensor name="camera_sensor" type="camera">
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <topic>/sensors/camera/image_raw</topic>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.1</near><far>50</far></clip>
        </camera>
      </sensor>
    </link>

    <!-- 雷达：车顶 2D 扫描 -->
    <link name="lidar_link">
      <pose>0 0 0.45 0 0 0</pose>
      <inertial><mass>0.1</mass><inertia><ixx>1e-4</ixx><iyy>1e-4</iyy><izz>1e-4</izz></inertia></inertial>
      <visual name="lidar_visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.035</radius><length>0.025</length></cylinder></geometry>
        <material><diffuse>0.06 0.06 0.07 1</diffuse></material>
      </visual>
      <sensor name="lidar_sensor" type="gpu_lidar">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <visualize>true</visualize>
        <topic>/sensors/lidar/scan</topic>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>1</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>0</max_angle>
            </vertical>
          </scan>
          <range><min>0.15</min><max>30.0</max><resolution>0.01</resolution></range>
        </lidar>
      </sensor>
    </link>

    <link name="front_left_wheel">
      <pose>0.4 0.42 0.16 0 0 0</pose>
      <inertial><mass>1</mass><inertia><ixx>0.02</ixx><iyy>0.02</iyy><izz>0.02</izz></inertia></inertial>
      <visual name="tire"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.13</radius><length>0.10</length></cylinder></geometry><material><diffuse>0.10 0.10 0.10 1</diffuse></material></visual>
      <visual name="rim"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.07</radius><length>0.11</length></cylinder></geometry><material><diffuse>0.78 0.78 0.82 1</diffuse></material></visual>
      <collision name="collision"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.16</radius><length>0.08</length></cylinder></geometry><surface><friction><ode><mu>0.4</mu><mu2>0.4</mu2></ode></friction></surface></collision>
    </link>
    <link name="front_right_wheel">
      <pose>0.4 -0.42 0.16 0 0 0</pose>
      <inertial><mass>1</mass><inertia><ixx>0.02</ixx><iyy>0.02</iyy><izz>0.02</izz></inertia></inertial>
      <visual name="tire"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.13</radius><length>0.10</length></cylinder></geometry><material><diffuse>0.10 0.10 0.10 1</diffuse></material></visual>
      <visual name="rim"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.07</radius><length>0.11</length></cylinder></geometry><material><diffuse>0.78 0.78 0.82 1</diffuse></material></visual>
      <collision name="collision"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.16</radius><length>0.08</length></cylinder></geometry><surface><friction><ode><mu>0.4</mu><mu2>0.4</mu2></ode></friction></surface></collision>
    </link>
    <link name="left_rear_wheel">
      <pose>-0.4 0.42 0.16 0 0 0</pose>
      <inertial><mass>1</mass><inertia><ixx>0.02</ixx><iyy>0.02</iyy><izz>0.02</izz></inertia></inertial>
      <visual name="tire"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.17</radius><length>0.12</length></cylinder></geometry><material><diffuse>0.10 0.10 0.10 1</diffuse></material></visual>
      <visual name="rim"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.09</radius><length>0.13</length></cylinder></geometry><material><diffuse>0.78 0.78 0.82 1</diffuse></material></visual>
      <collision name="collision"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.16</radius><length>0.08</length></cylinder></geometry><surface><friction><ode><mu>1.3</mu><mu2>1.3</mu2></ode></friction></surface></collision>
    </link>
    <link name="right_rear_wheel">
      <pose>-0.4 -0.42 0.16 0 0 0</pose>
      <inertial><mass>1</mass><inertia><ixx>0.02</ixx><iyy>0.02</iyy><izz>0.02</izz></inertia></inertial>
      <visual name="tire"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.17</radius><length>0.12</length></cylinder></geometry><material><diffuse>0.10 0.10 0.10 1</diffuse></material></visual>
      <visual name="rim"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.09</radius><length>0.13</length></cylinder></geometry><material><diffuse>0.78 0.78 0.82 1</diffuse></material></visual>
      <collision name="collision"><pose>0 0 0 1.5708 0 0</pose><geometry><cylinder><radius>0.16</radius><length>0.08</length></cylinder></geometry><surface><friction><ode><mu>1.3</mu><mu2>1.3</mu2></ode></friction></surface></collision>
    </link>

    <joint name="camera_joint" type="fixed"><parent>base_link</parent><child>camera_link</child></joint>
    <joint name="lidar_joint" type="fixed"><parent>base_link</parent><child>lidar_link</child></joint>
    <joint name="front_left_wheel_joint" type="revolute">
      <parent>base_link</parent><child>front_left_wheel</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>
    <joint name="front_right_wheel_joint" type="revolute">
      <parent>base_link</parent><child>front_right_wheel</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>
    <joint name="left_rear_wheel_joint" type="revolute">
      <parent>base_link</parent><child>left_rear_wheel</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>
    <joint name="right_rear_wheel_joint" type="revolute">
      <parent>base_link</parent><child>right_rear_wheel</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

  </model>
</sdf>
